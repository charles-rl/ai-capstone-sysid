<mujoco model="single link pendulum">
	<compiler inertiafromgeom="true"/>
    
    <!-- Added a white skybox and visual settings for a clean paper figure -->
    <visual>
        <global offwidth="1920" offheight="1080"/>
    </visual>
    <asset>
        <texture type="skybox" builtin="flat" rgb1="1 1 1" rgb2="1 1 1" width="512" height="512"/>
    </asset>

	<default>
		<joint armature="0" damping="1" limited="false"/>
		<geom contype="0" friction="1 0.1 0.1" rgba="0.7 0.7 0 1"/>
		<tendon/>
		<motor ctrlrange="-3 3"/>
	</default>
	<option gravity="0 0 -9.80665" integrator="RK4" timestep="0.001"/>
	<size nstack="3000"/>
	<worldbody>
        <camera name="main_cam" pos="0 -1.6 0" quat="0.707 0.707 0 0" />
        <!-- Added lighting to give the capsule depth -->
        <light directional="true" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" pos="0 -2 5" dir="0 2 -5"/>
        
        <body name="pole" pos="0 0 0">
            <joint axis="0 1 0" name="hinge" pos="0 0 0" limited="false" frictionloss="0" type="hinge"/>
            <geom fromto="0 0 0 0.001 0 0.6" name="cpole" rgba="0.2 0.2 0.25 1" size="0.049 0.3" density="1000" type="capsule"/>
        </body>
	</worldbody>
	<actuator>
		<motor ctrlrange="-3 3" gear="20" joint="hinge" name="hinge"/>
	</actuator>
</mujoco>